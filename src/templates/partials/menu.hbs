<nav aria-label="Main">
  <div class="menu" id="primary-nav-menu">
    {{#each pages as |page index|}}
      {{#if page.menuSubOf}}
      {{else}}
        {{#unless page.hideFromMenu}}
          {{#if page.menuSubpagesParent}}
            <div class="menu__group {{#equal page.activeMenuId ../activeMenu}}is-active-menu{{/equal}}">
              {{#equal page.activeMenuId ../activeMenu}}
                <div class="menu__lead is-active">
                  <a class="btn active menu__lead-link" href="{{ page.url }}">
                    {{{ page.pageTitle }}}
                  </a>
                  <button
                    type="button"
                    class="menu__expand"
                    data-menu-expand
                    aria-expanded="false"
                    aria-controls="primary-nav-menu"
                    aria-label="Show all pages"
                  >
                    <span class="caret" aria-hidden="true"><i class="fa fa-caret-down fa-2x"></i></span>
                  </button>
                </div>
              {{else}}
                <a class="btn" href="{{ page.url }}">
                  {{{ page.pageTitle }}}
                  <span class="caret" aria-hidden="true"><i class="fa fa-caret-down fa-2x"></i></span>
                </a>
              {{/equal}}
              <div class="menu__mobile-subs" role="group" aria-label="{{ page.pageTitle }}">
                {{#each ../pages as |subPage|}}
                  {{#if subPage.menuSubOf}}
                    {{#equal subPage.menuSubOf page.activeMenuId}}
                      <a
                        class="btn btn--menu-sub {{#equal subPage.url @root.activePath}}active{{/equal}}"
                        href="{{ subPage.url }}"
                      >
                        {{{ subPage.pageTitle }}}
                      </a>
                    {{/equal}}
                  {{/if}}
                {{/each}}
              </div>
            </div>
          {{else}}
            {{#equal page.activeMenuId ../activeMenu}}
              <div class="menu__lead is-active">
                <a class="btn active menu__lead-link" href="{{ page.url }}">
                  {{{ page.pageTitle }}}
                </a>
                <button
                  type="button"
                  class="menu__expand"
                  data-menu-expand
                  aria-expanded="false"
                  aria-controls="primary-nav-menu"
                  aria-label="Show all pages"
                >
                  <span class="caret" aria-hidden="true"><i class="fa fa-caret-down fa-2x"></i></span>
                </button>
              </div>
            {{else}}
              <a class="btn" href="{{ page.url }}">
                {{{ page.pageTitle }}}
                <span class="caret" aria-hidden="true"><i class="fa fa-caret-down fa-2x"></i></span>
              </a>
            {{/equal}}
          {{/if}}
        {{/unless}}
      {{/if}}
    {{/each}}
  </div>
</nav>
